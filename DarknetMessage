{
  "name": "DarknetMessage",
  "type": "object",
  "properties": {
    "sender_alias": {
      "type": "string",
      "description": "Villain alias of the sender"
    },
    "channel": {
      "type": "string",
      "enum": [
        "open",
        "alliance",
        "trade",
        "intelligence"
      ],
      "default": "open",
      "description": "Communication channel"
    },
    "message": {
      "type": "string",
      "description": "Encrypted message content"
    },
    "is_ai_generated": {
      "type": "boolean",
      "default": false,
      "description": "Whether the message was generated by the A.I."
    },
    "trade_offer": {
      "type": "string",
      "description": "Optional trade offer details"
    }
  },
  "required": [
    "sender_alias",
    "message"
  ]
}